# Copy this file to .env.local and fill in your values.

# Your GitHub username — used to fetch repos from the API.
# Leave blank to show placeholder project data.
GITHUB_USERNAME=your-github-username

# Optional: GitHub personal access token for higher API rate limits.
GH_API_TOKEN=

# Optional: repo name used as basePath for GitHub Pages subdirectory hosting.
# Example: if your site lives at username.github.io/portfolio, set this to /portfolio
BASE_PATH=
